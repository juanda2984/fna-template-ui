{
  "name": "fna-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:lib": "ng build fna-template-ui && xcopy /E /I /Y projects\\fna-template-ui\\assets dist\\fna-template-ui\\assets",
    "pack:lib": "npm pack dist/fna-template-ui",
    "publish:lib": "npm publish dist/fna-template-ui",
    "watch": "ng build --watch",
    "test": "ng test",
    "build:elements": "ng build --configuration production && node build-elements.js"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.0.0",
    "@angular/common": "21.0.0",
    "@angular/compiler": "21.0.0",
    "@angular/core": "21.0.0",
    "@angular/elements": "^21.0.0",
    "@angular/forms": "21.0.0",
    "@angular/platform-browser": "21.0.0",
    "@angular/platform-browser-dynamic": "21.0.0",
    "@angular/router": "21.0.0",
    "jquery": "^3.6.0",
    "rxjs": "7.8.1",
    "tslib": "2.8.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.0.0",
    "@angular/cli": "21.0.0",
    "@angular/compiler-cli": "21.0.0",
    "ng-packagr": "21.0.0",
    "typescript": "5.9.3"
  }
}
